#!/bin/bash

set -e
set -u

if [[ $# -lt 1 ]]; then
    echo "Usage: $0 <excel_file>"
    echo "Example: $0 plans/CEIC/my_plans.xlsx"
    exit 1
fi

EXCEL_FILE="$1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
OUTPUT_DIR="$(dirname "$EXCEL_FILE")"
PYTHON=python3

# Check if Excel file exists
if [[ ! -f "$EXCEL_FILE" ]]; then
    echo "Error: File not found: $EXCEL_FILE"
    exit 1
fi

echo "📊 Exporting plans from: $EXCEL_FILE"
$PYTHON "$SCRIPT_DIR/mapping_checker.py" "$EXCEL_FILE" --output-dir "$OUTPUT_DIR" -v

echo "✅ Export complete!"
echo ""
echo "🔍 Validating exported plans..."

# Find all exported plan JSON files (excluding offerings summary)
PLAN_FILES=$(find "$OUTPUT_DIR" -maxdepth 1 -name "*.json" ! -name "*_offerings.json" -type f | sort)

if [[ -z "$PLAN_FILES" ]]; then
    echo "⚠️  No plan files found to validate"
    exit 0
fi

resolve_rule_file() {
    local program_code="$1"
    local plan_stem="$2"
    local script_dir="$3"
    local intake_segment
    local intake_year
    local rule_file=""
    local candidate
    local candidate_basename
    local candidate_stem
    local range_part
    local range_start
    local range_end

    intake_segment="${plan_stem#${program_code}_}"
    if [[ "$intake_segment" != "$plan_stem" ]]; then
        intake_year="${intake_segment%%_*}"
    else
        intake_year=""
    fi

    if [[ "$intake_year" =~ ^[0-9]{4}$ ]]; then
        for candidate in "$script_dir"/rules/*.json; do
            candidate_basename="${candidate##*/}"
            candidate_stem="${candidate_basename%.json}"

            if [[ "$candidate_stem" == "$program_code"-* ]]; then
                range_part="${candidate_stem#${program_code}-}"
                range_start="${range_part%%-*}"
                range_end="${range_part##*-}"

                if [[ "$range_start" =~ ^[0-9]{4}$ ]] && [[ "$range_end" =~ ^[0-9]{4}$ ]] && (( intake_year >= range_start && intake_year <= range_end )); then
                    rule_file="$candidate"
                    break
                fi
            fi
        done
    fi

    if [[ -z "$rule_file" ]]; then
        rule_file="$script_dir/rules/${program_code}.json"
    fi

    printf '%s\n' "$rule_file"
}

# Validate each plan against rules
FAILED=0

for plan_file in $PLAN_FILES; do
    PLAN_BASENAME="${plan_file##*/}"
    PLAN_STEM="${PLAN_BASENAME%.json}"
    PROGRAM_CODE="${PLAN_STEM%%_*}"  # strip from first underscore onward
    RULE_FILE="$(resolve_rule_file "$PROGRAM_CODE" "$PLAN_STEM" "$SCRIPT_DIR")"

    echo -n "  Validating $(basename "$plan_file") against $(basename "$RULE_FILE")..."
    if [[ ! -f "$RULE_FILE" ]]; then
        echo " ⚠️  no rule file for $PROGRAM_CODE, skipping"
        continue
    fi
    set +e
    OUTPUT=$($PYTHON "$SCRIPT_DIR/degree_rules.py" "$RULE_FILE" --plan "$plan_file" 2>&1)
    EXIT_CODE=$?
    set -e
    
    if [[ $EXIT_CODE -eq 0 ]]; then
        echo "    ✓ Valid"
    else
        echo "    ❌ Validation failed"
        echo "$OUTPUT"
        ((++FAILED))
    fi
done

echo ""
if [[ $FAILED -eq 0 ]]; then
    echo "🎉 All plans validated successfully!"
    exit 0
else
    echo "❌ $FAILED plan(s) failed validation"
    exit 1
fi
